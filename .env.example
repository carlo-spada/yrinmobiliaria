# =============================================================================
# SUPABASE CONFIGURATION (REQUIRED)
# =============================================================================
# Next.js (App Router) lee estas variables NEXT_PUBLIC_* en cliente y servidor.
# Obtenlas en: Supabase Dashboard → Project Settings → API
# =============================================================================

# URL del proyecto Supabase (formato: https://xxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Clave pública/publishable (segura en cliente; solo permite acceso bajo RLS)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here

# ID del proyecto Supabase (Project Settings → General)
NEXT_PUBLIC_SUPABASE_PROJECT_ID=your_project_id

# =============================================================================
# SITIO (REQUIRED)
# =============================================================================

# Dominio público real (usado para canonical, OG, sitemap y robots)
NEXT_PUBLIC_SITE_URL=https://yrinmobiliaria.com

# =============================================================================
# ANALYTICS (Optional)
# =============================================================================

# Google Analytics Measurement ID (formato: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# =============================================================================
# WHATSAPP (Optional)
# =============================================================================

# Número de WhatsApp Business (código de país + número, sin espacios ni +)
# Ejemplo: 5219511234567 para México +52 951 123 4567
NEXT_PUBLIC_WHATSAPP_NUMBER=5219511234567

# =============================================================================
# CLOUDFLARE TURNSTILE (Optional — anti-abuso en formularios públicos)
# =============================================================================
# Site key PÚBLICA (segura en el navegador). Obtenla en Cloudflare → Turnstile.
# El secreto va como secret de edge function en Supabase (TURNSTILE_SECRET_KEY),
# NUNCA aquí. Si no se define, el widget no se renderiza y los formularios siguen
# funcionando (honeypot + rate-limit siguen activos).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAA...
